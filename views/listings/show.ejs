<% layout("./layouts/boilerplate.ejs") %>

<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card listing-show-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="Listing Image">

        <div class="card-body">
          <h2><%= listing.title %></h2>

          <p>Hosted by: <strong><%= listing.owner.username %></strong></p>
          <p class="text-muted"><%= listing.description %></p>

          <hr>

          <p><strong>Price:</strong> ₹ <%= listing.price.toLocaleString("en-IN") %>/Night</p>
          <p><strong>Location:</strong> <%= listing.location %></p>
          <p><strong>Country:</strong> <%= listing.country %></p>

          <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
            <div class="d-flex gap-2 mt-3">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">Edit</a>

              <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn btn-danger">Delete</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>

      <% if(currUser) { %>
      <div class="mt-5">
        <h4>Leave a Review</h4>

        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
          <h5 class="mb-3">Rate Your Experience</h5>

<fieldset class="starability-slot">
    <input type="radio"
           id="no-rate"
           class="input-no-rate"
           name="review[rating]"
           value="0"
           checked
           aria-label="No rating." />

    <input type="radio" id="rate1" name="review[rating]" value="1" />
    <label for="rate1" title="Terrible">1 star</label>

    <input type="radio" id="rate2" name="review[rating]" value="2" />
    <label for="rate2" title="Not good">2 stars</label>

    <input type="radio" id="rate3" name="review[rating]" value="3" />
    <label for="rate3" title="Average">3 stars</label>

    <input type="radio" id="rate4" name="review[rating]" value="4" />
    <label for="rate4" title="Very good">4 stars</label>

    <input type="radio" id="rate5" name="review[rating]" value="5" />
    <label for="rate5" title="Amazing">5 stars</label>
</fieldset>

          <div class="mb-3">
            <label class="form-label">Comments</label>
            <textarea name="review[comment]" class="form-control" rows="4" required></textarea>
          </div>

          <button class="btn btn-dark">Submit Review</button>
        </form>
      </div>
      <% } %>

      <hr class="my-5">

      <h4>All Reviews</h4>

      <div class="row">
        <% if(listing.reviews.length) { %>

          <% listing.reviews.forEach(review => { %>
            <div class="col-md-6 mb-3">
              <div class="card review-card">
                <div class="card-body">
                    <h5 class="card-title"> <%= review.author.username %></h5>
                  <p class="starability-result"
   data-rating="<%= review.rating %>">
   Rated: <%= review.rating %> stars
</p>
                  <p><%= review.comment %></p>
                <% if(currUser && review.author.equals(currUser._id)) { %>
                  <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-danger">Delete</button>
                  </form>
                <% } %>
                </div>
              </div>
            </div>
          <% }) %>

        <% } else { %>
          <p class="text-muted">No reviews yet.</p>
        <% } %>
      </div>

    </div>
  </div>
</div>