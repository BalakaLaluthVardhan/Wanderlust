<% layout("./layouts/boilerplate.ejs") %>

<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      
      <h3 class="mb-4 text-center">Edit Your Review</h3>

      <div class="card p-4 shadow-sm border-0">
        <h5 class="mb-3 text-muted">For: <%= listing.title %></h5>
        
        <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=PUT" method="POST" class="needs-validation" novalidate>
          
          <h6 class="mb-3">Update Rating</h6>
          
          <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" <%= review.rating === 0 ? 'checked' : '' %> aria-label="No rating." />
            
            <input type="radio" id="rate1" name="review[rating]" value="1" <%= review.rating === 1 ? 'checked' : '' %> />
            <label for="rate1" title="Terrible">1 star</label>
            
            <input type="radio" id="rate2" name="review[rating]" value="2" <%= review.rating === 2 ? 'checked' : '' %> />
            <label for="rate2" title="Not good">2 stars</label>
            
            <input type="radio" id="rate3" name="review[rating]" value="3" <%= review.rating === 3 ? 'checked' : '' %> />
            <label for="rate3" title="Average">3 stars</label>
            
            <input type="radio" id="rate4" name="review[rating]" value="4" <%= review.rating === 4 ? 'checked' : '' %> />
            <label for="rate4" title="Very good">4 stars</label>
            
            <input type="radio" id="rate5" name="review[rating]" value="5" <%= review.rating === 5 ? 'checked' : '' %> />
            <label for="rate5" title="Amazing">5 stars</label>
          </fieldset>

          <div class="mb-3">
            <label class="form-label fw-semibold">Comments</label>
            <textarea name="review[comment]" class="form-control" rows="4" required><%= review.comment %></textarea>
            <div class="invalid-feedback">Please provide a valid comment (min 5 characters).</div>
          </div>

          <div class="d-flex gap-2">
            <button class="btn btn-dark w-100">Update Review</button>
            <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary w-100">Cancel</a>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
