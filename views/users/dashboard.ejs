<% layout("./layouts/boilerplate.ejs") %>

<div class="container mt-4">
    <h2 class="mb-4 text-center">User Dashboard</h2>
    
    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs mb-4 justify-content-center" id="dashboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="listings-tab" data-bs-toggle="tab" data-bs-target="#listings" type="button" role="tab" aria-controls="listings" aria-selected="true">
                <i class="fa-solid fa-house-user"></i> My Listings (<%= listings.length %>)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="bookings-tab" data-bs-toggle="tab" data-bs-target="#bookings" type="button" role="tab" aria-controls="bookings" aria-selected="false">
                <i class="fa-solid fa-calendar-check"></i> My Bookings (<%= bookings.length %>)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab" aria-controls="reviews" aria-selected="false">
                <i class="fa-solid fa-star-half-stroke"></i> My Reviews (<%= reviews.length %>)
            </button>
        </li>
    </ul>

    <!-- Tab Contents -->
    <div class="tab-content mb-5" id="dashboardTabsContent">
        <!-- MY LISTINGS TAB -->
        <div class="tab-pane fade show active" id="listings" role="tabpanel" aria-labelledby="listings-tab">
            <div class="row">
                <% if(listings.length > 0) { %>
                    <% for(let list of listings) { %>
                        <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                            <div class="card listing-card shadow-sm h-100">
                                <img src="<%= list.image.url %>" class="card-img-top" alt="listing-image" style="height: 200px; object-fit: cover;">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold"><%= list.title %></h5>
                                    <p class="card-text text-muted mb-3"><%= list.location %>, <%= list.country %></p>
                                    <div class="mt-auto d-flex gap-2">
                                        <a href="/listings/<%= list._id %>" class="btn btn-sm btn-outline-dark flex-grow-1">View</a>
                                        <a href="/listings/<%= list._id %>/edit" class="btn btn-sm btn-warning">Edit</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <i class="fa-solid fa-hotel fs-1 text-muted mb-3"></i>
                        <h5>No listings published yet.</h5>
                        <p class="text-muted">Become a host and list your property on Wanderlust!</p>
                        <a href="/listings/new" class="btn btn-danger btn-sm">Host a Property</a>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- MY BOOKINGS TAB -->
        <div class="tab-pane fade" id="bookings" role="tabpanel" aria-labelledby="bookings-tab">
            <div class="row">
                <% if(bookings.length > 0) { %>
                    <% for(let booking of bookings) { %>
                        <div class="col-md-6 mb-4">
                            <div class="card shadow-sm h-100 border-0 rounded-3 overflow-hidden">
                                <div class="row g-0 h-100">
                                    <div class="col-sm-5">
                                        <img src="<%= booking.listing.image.url %>" class="img-fluid h-100 w-100" alt="listing-image" style="min-height: 180px; object-fit: cover;">
                                    </div>
                                    <div class="col-sm-7">
                                        <div class="card-body d-flex flex-column h-100">
                                            <h5 class="card-title fw-bold"><%= booking.listing.title %></h5>
                                            <p class="card-text text-muted mb-2">
                                                <i class="fa-regular fa-calendar"></i> <%= booking.checkIn.toDateString() %> <br>to <%= booking.checkOut.toDateString() %>
                                            </p>
                                            <p class="card-text fw-bold text-danger mb-3">
                                                Total Paid: ₹<%= booking.totalPrice.toLocaleString("en-IN") %>
                                            </p>
                                            <div class="mt-auto">
                                                <form method="POST" action="/bookings/<%= booking._id %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                                    <button class="btn btn-sm btn-outline-danger w-100">Cancel Booking</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <i class="fa-solid fa-umbrella-beach fs-1 text-muted mb-3"></i>
                        <h5>No reservations made yet.</h5>
                        <p class="text-muted">Start searching and plan your next destination!</p>
                        <a href="/listings" class="btn btn-danger btn-sm">Explore Listings</a>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- MY REVIEWS TAB -->
        <div class="tab-pane fade" id="reviews" role="tabpanel" aria-labelledby="reviews-tab">
            <div class="row">
                <% if(reviews.length > 0) { %>
                    <% for(let review of reviews) { %>
                        <% 
                        // Find corresponding listing
                        let matchingList = listingsWithReviews.find(list => list.reviews.some(r => r._id.toString() === review._id.toString())); 
                        %>
                        <div class="col-md-6 mb-3">
                            <div class="card review-card h-100">
                                <div class="card-body d-flex flex-column">
                                    <% if (matchingList) { %>
                                        <h5 class="card-title fw-bold text-dark"><a href="/listings/<%= matchingList._id %>" class="text-decoration-none text-dark"><%= matchingList.title %></a></h5>
                                    <% } else { %>
                                        <h5 class="card-title fw-bold text-muted">Unknown Listing</h5>
                                    <% } %>
                                    <p class="starability-result mb-2" data-rating="<%= review.rating %>">
                                        Rated: <%= review.rating %> stars
                                    </p>
                                    <p class="card-text text-muted flex-grow-1">"<%= review.comment %>"</p>
                                    
                                    <div class="mt-3 d-flex gap-2">
                                        <% if(matchingList) { %>
                                            <a href="/listings/<%= matchingList._id %>/reviews/<%= review._id %>/edit" class="btn btn-sm btn-outline-dark flex-grow-1 text-center py-2" style="border-radius: 0.75rem;">Edit</a>
                                            <form method="POST" action="/listings/<%= matchingList._id %>/reviews/<%= review._id %>?_method=DELETE" class="flex-grow-1">
                                                <button class="btn btn-sm btn-danger w-100 py-2">Delete</button>
                                            </form>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <i class="fa-solid fa-comments fs-1 text-muted mb-3"></i>
                        <h5>No reviews submitted yet.</h5>
                        <p class="text-muted">Share your experiences on listings you have visited!</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
