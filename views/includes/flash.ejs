<% if(success && success.length) { %>
<div class="alert alert-success alert-dismissible fade show custom-flash-alert" role="alert">
  <i class="fa-solid fa-circle-check text-success fs-5 me-2"></i>
  <span><%= success %></span>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="padding: 1rem 1.5rem;"></button>
</div>
<% } %>

<% if(error && error.length) { %>
<div class="alert alert-danger alert-dismissible fade show custom-flash-alert" role="alert">
  <i class="fa-solid fa-circle-xmark text-danger fs-5 me-2"></i>
  <span><%= error %></span>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="padding: 1rem 1.5rem;"></button>
</div>
<% } %>